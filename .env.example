# Get a free API key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# moomoo OpenD(期权链)
MOOMOO_WS_HOST=127.0.0.1
MOOMOO_WS_PORT=33333
MOOMOO_WS_KEY=

# scripts/daily-with-opend.sh 用:headless 拉起命令行版 OpenD(留空=只在 OpenD 已运行时跑)。
# 用命令行版二进制(OpenD,非 GUI 的 moomoo_OpenD)。值带空格,整体用双引号包起来。
# 新设备首次登录要手机验证码;图形验证码仅在"多次输错密码"后才触发。
# -telnet_port=22222 开命令端口:万一要验证码,可 telnet 进去 input_pic_verify_code/input_phone_verify_code 喂码。
# OPEND_CMD="/路径/OpenD.app/Contents/MacOS/OpenD -login_account=XXXX -login_pwd_md5=XXXX -lang=en -log_level=no -console=0 -no_monitor=1 -telnet_port=22222"
OPEND_CMD=
