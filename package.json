{
  "name": "my-trading-view",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta --kill-others-on-fail \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun run --watch src/server/index.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "job:daily": "bun run src/server/jobs/daily.ts",
    "job:daily:opend": "scripts/daily-with-opend.sh",
    "job:crypto": "bun run src/server/jobs/cryptoDaily.ts",
    "db:migrate": "bun run src/server/storage/db.ts migrate",
    "test": "bun test",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "bun node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.18",
    "fflate": "^0.8.3",
    "hono": "^4.6.0",
    "lightweight-charts": "^5.0.0",
    "lucide-react": "^1.23.0",
    "moomoo-api": "^10.7.6708",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "remeda": "^2.39.0",
    "swr": "^2.4.1",
    "yahoo-finance2": "^3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^7.0.0",
    "vite": "^5.4.0"
  }
}
